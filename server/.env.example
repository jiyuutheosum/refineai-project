# ============================================
# RefineAI Backend Environment Variables
# Copy this file to .env and fill in values
# ============================================

PORT=4000
NODE_ENV=development

# ============================================
# 🔥 Firebase Admin SDK Credentials (CRITICAL)
# ============================================
# The backend WILL CRASH without this.

# === RECOMMENDED FOR LOCAL DEVELOPMENT ===
# 1. Download your service account key JSON from Firebase Console
# 2. Put the file in this folder and rename it to: serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_PATH=

# === FOR HOSTING PLATFORMS (Render, Railway, etc.) ===
# Paste the full JSON as one long line instead:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"refine-ai-project", ...}

# Your project ID
FIREBASE_PROJECT_ID=

# Allow your frontend (Vite runs on 5173 by default)
CORS_ORIGIN=

# Server-side Groq key (this is NOT the VITE_ version)
GROQ_API_KEY=your_real_groq_key_here
