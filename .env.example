# This is an example .env file. Copy this to .env and fill in the values to run the project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI keys are NO LONGER needed on the client. All AI calls are proxied via the backend (/server)
# which uses its own GROQ_API_KEY (server/.env). These VITE_*_API_KEY lines can be removed
# or left blank. Only Firebase + Adzuna (optional) + VITE_BACKEND_URL are required for the frontend.
VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=  # DEPRECATED for client - backend only now

# FOR JOB SEARCH INTEGRATION
VITE_ADZUNA_APP_ID=
VITE_ADZUNA_APP_KEY=

# Backend API (our Express server with rate limiting + secure AI calls)
# Default: http://localhost:4000 (matches the /server we scaffolded)
VITE_BACKEND_URL=
