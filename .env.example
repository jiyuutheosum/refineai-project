# This is an example .env file. Copy this to .env and fill in the values to run the project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# FOR AI INTEGRATIONS, YOU CAN USE EITHER GEMINI OR GROQ. MAKE SURE TO FILL IN THE ONE YOU CHOOSE AND LEAVE THE OTHER BLANK.
VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=

# FOR JOB SEARCH INTEGRATION
VITE_ADZUNA_APP_ID=
VITE_ADZUNA_APP_KEY=

# Backend API (our Express server with rate limiting + secure AI calls)
# Default: http://localhost:4000 (matches the /server we scaffolded)
VITE_BACKEND_URL=
